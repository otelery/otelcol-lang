{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OTTL",
  "scopeName": "source.ottl",
  "fileTypes": ["ottl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#literals" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ottl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ottl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ottl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ottl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.bytes.ottl",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.ottl",
          "match": "(?<![\\w.])[+-]?(\\d+\\.\\d+|\\.\\d+|\\d+\\.)([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.ottl",
          "match": "(?<![\\w.])[+-]?\\d+\\b"
        },
        {
          "name": "constant.language.boolean.ottl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.ottl",
          "match": "\\bnil\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.where.ottl",
          "match": "\\bwhere\\b"
        },
        {
          "name": "keyword.operator.logical.ottl",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ottl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.ottl",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.named-arg.ottl",
          "match": "(?<=\\b[a-z][a-zA-Z0-9_]*)\\s*=(?!=)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.parens.begin.ottl", "match": "\\(" },
        { "name": "punctuation.section.parens.end.ottl", "match": "\\)" },
        { "name": "punctuation.section.brackets.begin.ottl", "match": "\\[" },
        { "name": "punctuation.section.brackets.end.ottl", "match": "\\]" },
        { "name": "punctuation.section.braces.begin.ottl", "match": "\\{" },
        { "name": "punctuation.section.braces.end.ottl", "match": "\\}" },
        { "name": "punctuation.separator.comma.ottl", "match": "," },
        { "name": "punctuation.accessor.dot.ottl", "match": "\\." },
        { "name": "punctuation.separator.colon.ottl", "match": ":" },
        { "name": "punctuation.terminator.statement.ottl", "match": ";" }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Editor: lowercase identifier immediately before '('",
          "name": "entity.name.function.editor.ottl",
          "match": "\\b([a-z][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "comment": "Converter: CamelCase identifier immediately before '('",
          "name": "entity.name.function.converter.ottl",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "comment": "Enum: uppercase identifier NOT followed by '('",
          "name": "constant.other.enum.ottl",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b(?!\\s*\\()"
        },
        {
          "comment": "Path/field: lowercase identifier",
          "name": "entity.other.attribute-name.ottl",
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
