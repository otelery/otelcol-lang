<idea-plugin>
  <id>ch.snowgarden.otelcol</id>
  <name>OpenTelemetry Collector Config</name>
  <vendor email="opensource@snowgarden.ch" url="https://github.com/otelery/otelcol-lang">otelery</vendor>

  <description><![CDATA[
    Syntax highlighting and language support for OpenTelemetry Collector
    configuration files (<code>*.otelcol.yaml</code>) and the OpenTelemetry
    Transformation Language (OTTL).
    <br/>
    Backed by the standalone <code>otelcol-language-server</code> binary
    (install via <code>npm i -g otelcol-language-server</code> or from the
    repository tarball).
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.redhat.devtools.lsp4ij</depends>
  <depends>org.jetbrains.plugins.textmate</depends>
  <depends>org.jetbrains.plugins.yaml</depends>

  <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
    <server
        id="otelcol"
        name="OpenTelemetry Collector"
        factoryClass="ch.snowgarden.otelcol.OtelcolLspServerFactory"/>
    <languageMapping
        language="yaml"
        serverId="otelcol"
        languageId="otelcol"/>
    <!-- Colorize component references (namespace) and declarations (class)
         using the user's theme-aware highlighter palette, matching the VS
         Code styling. Without this, LSP4IJ leaves these tokens unstyled
         and they render as plain text. -->
    <semanticTokensColorsProvider
        serverId="otelcol"
        class="ch.snowgarden.otelcol.OtelcolSemanticTokensColorsProvider"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.plugins.textmate">
    <bundleProvider implementation="ch.snowgarden.otelcol.OtelcolTextMateBundle"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
        name="OpenTelemetry Collector"
        implementationClass="ch.snowgarden.otelcol.OtelcolFileType"
        fieldName="INSTANCE"
        patterns="*.otelcol.yaml;*.otelcol.yml;otelcol-configset.yaml"/>
    <registryKey
        key="otelcol.lsp.server.path"
        defaultValue=""
        description="Absolute path to the otelcol LSP server.js. Leave blank to use the bundled copy. Restart the language server (Tools → Restart otelcol Language Server) after changing."
        restartRequired="false"/>
    <postStartupActivity implementation="ch.snowgarden.otelcol.OtelcolDevWatcher"/>
  </extensions>

  <actions>
    <action id="otelcol.RestartLspServer"
            class="ch.snowgarden.otelcol.RestartOtelcolServerAction"
            text="Restart otelcol Language Server"
            description="Stop and start the otelcol LSP server process for the current project">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
