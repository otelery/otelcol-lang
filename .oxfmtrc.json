{
  "$schema": "https://oxc.rs/schemas/oxfmt.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "out/",
    "schemas/",
    "syntaxes/",
    "editors/jetbrains/src/main/resources/textmate/",
    "test/configsets/",
    "package-lock.json",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ]
}
