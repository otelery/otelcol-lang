{
  "name": "vscode-otelcol",
  "displayName": "OpenTelemetry Collector",
  "version": "0.1.0",
  "description": "Syntax highlighting, completion, hover, diagnostics and embedded OTTL for OpenTelemetry Collector configs.",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/otelery/otelcol-lang"
  },
  "publisher": "otelery",
  "bin": {
    "otelcol-language-server": "./bin/otelcol-language-server.js"
  },
  "main": "./dist/extension/extension.js",
  "scripts": {
    "watch": "node esbuild.js --watch",
    "compile": "node esbuild.js",
    "smoke": "node scripts/smoke.mjs",
    "smoke:stdio": "node scripts/smoke-stdio.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.0",
    "@types/vscode": "^1.91.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "otelcol",
        "aliases": [
          "OpenTelemetry Collector",
          "otelcol"
        ],
        "extensions": [],
        "firstLine": "^#\\s*(otelcol|opentelemetry-collector)\\b",
        "configuration": "./editors/vscode/language-configuration.json"
      },
      {
        "id": "ottl",
        "aliases": [
          "OTTL",
          "OpenTelemetry Transformation Language"
        ],
        "extensions": [
          ".ottl"
        ],
        "configuration": "./editors/vscode/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "otelcol",
        "scopeName": "source.yaml.otelcol",
        "path": "./syntaxes/otelcol-yaml.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.ottl": "ottl"
        }
      },
      {
        "language": "ottl",
        "scopeName": "source.ottl",
        "path": "./syntaxes/ottl.tmLanguage.json"
      },
      {
        "scopeName": "source.yaml.otelcol.substitution",
        "path": "./syntaxes/otelcol-substitution.injection.json",
        "injectTo": [
          "source.yaml.otelcol"
        ]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "otelcol",
        "scopes": {
          "class": [
            "entity.name.type.class"
          ],
          "class.declaration": [
            "entity.name.type.class.declaration"
          ],
          "class.declaration.deprecated": [
            "invalid.deprecated"
          ],
          "namespace": [
            "entity.name.namespace"
          ],
          "namespace.declaration": [
            "entity.name.namespace.declaration"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[otelcol]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "meta.variable.substitution.otelcol support.function.builtin.otelcol",
            "settings": {
              "foreground": "#C678DD",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol variable.other.otelcol",
            "settings": {
              "foreground": "#E06C75"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol keyword.operator.default.otelcol",
            "settings": {
              "foreground": "#56B6C2"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol string.unquoted.default.otelcol",
            "settings": {
              "foreground": "#98C379"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol punctuation.definition.variable.begin.otelcol",
            "settings": {
              "foreground": "#ABB2BF"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol punctuation.definition.variable.end.otelcol",
            "settings": {
              "foreground": "#ABB2BF"
            }
          },
          {
            "scope": "meta.variable.substitution.otelcol punctuation.separator.key-value.otelcol",
            "settings": {
              "foreground": "#ABB2BF"
            }
          },
          {
            "scope": "invalid.deprecated.otelcol",
            "settings": {
              "foreground": "#5C6370",
              "fontStyle": "strikethrough"
            }
          }
        ]
      },
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "class.declaration:otelcol": {
            "foreground": "#E5C07B",
            "bold": true
          },
          "class:otelcol": {
            "foreground": "#E5C07B"
          },
          "class.declaration.deprecated:otelcol": {
            "foreground": "#5C6370",
            "strikethrough": true
          },
          "namespace.declaration:otelcol": {
            "foreground": "#C678DD",
            "bold": true
          },
          "namespace:otelcol": {
            "foreground": "#C678DD"
          }
        }
      }
    },
    "configuration": {
      "title": "OpenTelemetry Collector",
      "properties": {
        "otelcol.distribution": {
          "type": "string",
          "enum": [
            "otelcol",
            "otelcol-contrib",
            "otelcol-k8s",
            "otelcol-otlp",
            "otelcol-ebpf-profiler",
            "datadog-otelcol",
            "elastic-otelcol"
          ],
          "default": "otelcol-contrib",
          "description": "Which Collector distribution to validate against. Determines which components are 'known' and which schemas are used. Defaults to otelcol-contrib."
        },
        "otelcol.schemaSource": {
          "type": "string",
          "default": "",
          "description": "Reserved for future use. Will allow loading schemas from an HTTPS URL or a pinned release tag of otelcol-schemas instead of the bundled copy. No effect in v0.1.0."
        },
        "otelcol.contribPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a local opentelemetry-collector-contrib checkout. Used to look up README docs on hover."
        },
        "otelcol.ottlLspPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the ottl-lsp executable for embedded OTTL diagnostics."
        },
        "otelcol.configSets.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically group YAML files into config sets by searching the workspace for `service.pipelines:` anchors. An anchor at directory D owns fragments in D and its subdirectories, stopping at any nested anchor. Disable to require an explicit `otelcol-configset.yaml` sidecar or `# otelcol-configset:` directive."
        },
        "otelcol.configSets.maxFilesScanned": {
          "type": "integer",
          "default": 2000,
          "description": "Safety bound on the workspace scan for config-set discovery."
        },
        "otelcol.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication."
        },
        "otelcol.sniffer.trace": {
          "type": "boolean",
          "default": false,
          "description": "Log per-file YAML → otelcol retag decisions to the 'Otelcol Sniffer' output channel. Useful for diagnosing why a configset fragment is or isn't being detected."
        },
        "otelcol.attachToYaml": {
          "type": "boolean",
          "default": false,
          "description": "Server-side sniffer fallback. When true, the LSP runs the same content-based detection that VSCode uses client-side on any 'yaml' document the client sends, and emits diagnostics/semantic-tokens only for matches. Off by default in VSCode (the extension's sniffer already retags). Recommended for Zed and other editors that can't retag documents based on content."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:otelcol",
    "onLanguage:yaml"
  ],
  "engines": {
    "node": ">=22",
    "vscode": "^1.91.0"
  }
}
