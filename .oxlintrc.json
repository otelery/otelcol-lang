{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn",
    "style": "off"
  },
  "env": {
    "node": true
  },
  "rules": {
    "no-underscore-dangle": ["warn", { "allow": ["__dirname"] }],
    "no-await-in-loop": "off",
    "unicorn/no-array-sort": "off"
  },
  "ignorePatterns": ["node_modules", "dist", "out", "schemas", "syntaxes", "test/configsets"]
}
