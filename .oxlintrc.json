{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn",
    "style": "off"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "out",
    "schemas",
    "syntaxes",
    "test/configsets"
  ]
}
